;; reward_engine_RewardEngine.storage.fc
;;
;; Type: RewardEngine
;; TLB: _ ownerAddress:address rateValue:int257 accruedValue:int257 = RewardEngine
;;

builder $RewardEngine$_store(builder build_0, (slice, int, int) v) inline {
    var (v'ownerAddress, v'rateValue, v'accruedValue) = v;
    build_0 = build_0.store_slice(v'ownerAddress);
    build_0 = build_0.store_int(v'rateValue, 257);
    build_0 = build_0.store_int(v'accruedValue, 257);
    return build_0;
}

(slice, ((slice, int, int))) $RewardEngine$_load(slice sc_0) inline {
    var v'ownerAddress = sc_0~load_msg_addr();
    var v'rateValue = sc_0~load_int(257);
    var v'accruedValue = sc_0~load_int(257);
    return (sc_0, (v'ownerAddress, v'rateValue, v'accruedValue));
}

(slice, ((slice))) $RewardEngine$init$_load(slice sc_0) inline {
    var v'owner = sc_0~load_msg_addr();
    return (sc_0, (v'owner));
}

(slice, int, int) $RewardEngine$_contract_load() impure inline {
    slice $sc = get_data().begin_parse();
    int $loaded = $sc~load_int(1);
    if ($loaded) {
        return $sc~$RewardEngine$_load();
    }
    else {
        (slice $owner) = $sc~$RewardEngine$init$_load();
        $sc.end_parse();
        return $RewardEngine$_contract_init($owner);
    }
}

() $RewardEngine$_contract_store((slice, int, int) v) impure inline {
    builder b = begin_cell();
    b = b.store_int(true, 1);
    b = $RewardEngine$_store(b, v);
    set_data(b.end_cell());
}

