(slice, int, int) $RewardEngine$_contract_init(slice $owner) impure inline {
    var (($self'ownerAddress, $self'rateValue, $self'accruedValue)) = (null(), 1, 0);
    $self'ownerAddress = $owner;
    return ($self'ownerAddress, $self'rateValue, $self'accruedValue);
}

((slice, int, int), slice) $RewardEngine$_fun_owner((slice, int, int) $self) impure inline_ref {
    var (($self'ownerAddress, $self'rateValue, $self'accruedValue)) = $self;
    var $fresh$ret_4 = $self'ownerAddress;
    return (($self'ownerAddress, $self'rateValue, $self'accruedValue), $fresh$ret_4);
}

((slice, int, int), int) $RewardEngine$_fun_rewardRate((slice, int, int) $self) impure inline_ref {
    var (($self'ownerAddress, $self'rateValue, $self'accruedValue)) = $self;
    var $fresh$ret_5 = $self'rateValue;
    return (($self'ownerAddress, $self'rateValue, $self'accruedValue), $fresh$ret_5);
